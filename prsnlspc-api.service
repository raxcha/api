[Unit]
Description=prsnl.spc API
After=network-online.target
Wants=network-online.target

[Service]
Type=simple
User=asdf
Group=asdf
WorkingDirectory=/home/asdf/api
EnvironmentFile=/home/asdf/api/env-api.env
ExecStart=/usr/bin/go run ./cmd/server
Restart=on-failure
RestartSec=3
NoNewPrivileges=true
PrivateTmp=true
ProtectSystem=full
ReadWritePaths=/home/asdf/api

[Install]
WantedBy=multi-user.target
